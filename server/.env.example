# Environment
NODE_ENV=development
PORT=5000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL or Local PostgreSQL)
# Supabase: postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
# Local: postgresql://postgres:postgres@localhost:5432/banquet_db?schema=public
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Direct connection (optional, redundant for local)
DIRECT_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# JWT (Supabase uses its own JWT secret — find it in Supabase Dashboard → Settings → API)
JWT_SECRET=your-supabase-jwt-secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
